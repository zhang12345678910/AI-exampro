/* pages/dictionary/detail/index.wxss - 名词详情页 (宇宙星空主题) */

.container {
  position: relative;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 头部区域 */
.detail-header {
  padding: 96rpx 32rpx 32rpx;
}

.term-title-section {
  margin-bottom: 24rpx;
}

.term-name {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
  font-family: var(--font-display);
  margin-bottom: 12rpx;
  background: linear-gradient(135deg, #00d9ff 0%, #b794f6 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.term-name-en {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 24rpx;
}

.term-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.difficulty-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-primary {
  background: rgba(0, 217, 255, 0.15);
  color: #00d9ff;
}

.tag-secondary {
  background: rgba(183, 148, 246, 0.15);
  color: #b794f6;
}

.tag-accent {
  background: rgba(236, 72, 153, 0.15);
  color: #ec4899;
}

.category-tag {
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 内容滚动区域 */
.content-scroll {
  height: calc(100vh - 160rpx);
  padding: 0 32rpx;
}

/* 通用区块 */
.definition-section,
.examples-section,
.related-section {
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.definition-section::before,
.examples-section::before,
.related-section::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(0, 217, 255, 0.05) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.5s ease;
}

.definition-section:active::before,
.examples-section:active::before,
.related-section:active::before {
  opacity: 1;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.definition-content {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.8;
  text-align: justify;
}

.divider {
  height: 1rpx;
  background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.1), transparent);
  margin: 24rpx 0;
}

.professional-definition {
  margin-top: 24rpx;
  padding-top: 24rpx;
}

/* 例句区域 */
.examples-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.example-card {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.example-card:active {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(0, 217, 255, 0.2);
}

.example-scenario {
  display: block;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.example-content {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
}

/* 标签区域 */
.tags-section {
  margin-bottom: 24rpx;
}

.section-header-small {
  margin-bottom: 16rpx;
}

.section-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-item {
  padding: 10rpx 20rpx;
  background: rgba(0, 217, 255, 0.1);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #00d9ff;
}

/* 相关名词 */
.related-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.related-item {
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.related-item:active {
  background: rgba(0, 217, 255, 0.08);
  border-color: rgba(0, 217, 255, 0.3);
  transform: translateX(8rpx);
}

.related-item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.related-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.related-category {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 底部占位 */
.bottom-spacer {
  height: 120rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: rgba(15, 23, 42, 0.95);
  backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 0;
  transition: all 0.3s ease;
}

.action-item:active {
  transform: scale(0.95);
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 笔记编辑器弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8rpx);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  width: 100%;
  max-width: 640rpx;
  background: rgba(15, 23, 42, 0.95);
  backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.9);
}

.modal-close {
  font-size: 56rpx;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1;
  padding: 0 16rpx;
}

.note-input {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.note-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.note-actions {
  display: flex;
  gap: 16rpx;
}

.note-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.delete-btn {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.7);
}

.delete-btn:active {
  background: rgba(255, 255, 255, 0.15);
}

.save-btn {
  background: linear-gradient(135deg, #00d9ff 0%, #b794f6 100%);
  color: white;
  box-shadow: 0 8rpx 32rpx rgba(0, 217, 255, 0.3);
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 217, 255, 0.2);
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: #00d9ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
}

/* 空状态 */
.empty-container {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
  margin-bottom: 24rpx;
}

.empty-text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}

.empty-btn {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background: rgba(0, 217, 255, 0.15);
  border: 1rpx solid rgba(0, 217, 255, 0.3);
  border-radius: 24rpx;
  color: #00d9ff;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-btn:active {
  background: rgba(0, 217, 255, 0.2);
}
