<!--pages/dictionary/detail/index.wxml - 名词详情页 (宇宙星空主题)-->
<view class="container">
  <!-- 宇宙背景 -->
  <view class="cosmic-bg"></view>
  
  <!-- 加载中 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加载...</text>
  </view>

  <!-- 详情内容 -->
  <scroll-view 
    class="content-scroll" 
    scroll-y 
    enhanced
    show-scrollbar="{{false}}"
    wx:if="{{!loading && term}}"
  >
    <!-- 头部区域 -->
    <view class="detail-header">
      <view class="term-title-section">
        <text class="term-name">{{term.name}}</text>
        <text class="term-name-en" wx:if="{{term.nameEn}}">{{term.nameEn}}</text>
        
        <view class="term-tags">
          <view class="difficulty-tag tag-primary" wx:if="{{term.difficulty === 1}}">入门</view>
          <view class="difficulty-tag tag-secondary" wx:if="{{term.difficulty === 2}}">进阶</view>
          <view class="difficulty-tag tag-accent" wx:if="{{term.difficulty === 3}}">专业</view>
          <view class="category-tag">{{term.category}}</view>
        </view>
      </view>
    </view>

    <!-- 释义区域 -->
    <view class="definition-section glass-card">
      <view class="section-header">
        <text class="section-icon">📖</text>
        <text class="section-title">通俗解释</text>
      </view>
      <text class="definition-content">
        {{term.definition ? (term.definition.simple || term.definition) : '暂无解释'}}
      </text>
      
      <!-- 专业定义 -->
      <view class="professional-definition" wx:if="{{term.definition && term.definition.professional}}">
        <view class="divider"></view>
        <view class="section-header">
          <text class="section-icon">📚</text>
          <text class="section-title">专业定义</text>
        </view>
        <text class="definition-content">{{term.definition.professional}}</text>
      </view>
    </view>

    <!-- 典型例句 -->
    <view class="examples-section glass-card" wx:if="{{term.examples && term.examples.length > 0}}">
      <view class="section-header">
        <text class="section-icon">💡</text>
        <text class="section-title">典型例句</text>
      </view>
      
      <view class="examples-list">
        <view class="example-card" wx:for="{{term.examples}}" wx:key="index">
          <text class="example-scenario">{{item.scenario}}</text>
          <text class="example-content">{{item.content}}</text>
        </view>
      </view>
    </view>

    <!-- 标签 -->
    <view class="tags-section" wx:if="{{term.tags && term.tags.length > 0}}">
      <view class="section-header-small">
        <text class="section-text">标签</text>
      </view>
      <view class="tags-list">
        <view class="tag-item" wx:for="{{term.tags}}" wx:key="*this">
          #{{item}}
        </view>
      </view>
    </view>

    <!-- 相关名词 -->
    <view class="related-section glass-card" wx:if="{{relatedTerms && relatedTerms.length > 0}}">
      <view class="section-header">
        <text class="section-icon">🔗</text>
        <text class="section-title">相关名词</text>
      </view>
      
      <view class="related-list">
        <view 
          class="related-item"
          wx:for="{{relatedTerms}}"
          wx:key="_id"
          data-id="{{item._id}}"
          bindtap="goToRelatedTerm"
        >
          <view class="related-item-header">
            <text class="related-name">{{item.name}}</text>
            <view class="difficulty-tag tag-primary" wx:if="{{item.difficulty === 1}}">入门</view>
            <view class="difficulty-tag tag-secondary" wx:if="{{item.difficulty === 2}}">进阶</view>
            <view class="difficulty-tag tag-accent" wx:if="{{item.difficulty === 3}}">专业</view>
          </view>
          <text class="related-category">{{item.category}}</text>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- 空状态 -->
  <view class="empty-container" wx:if="{{!term && !loading}}">
    <text class="empty-icon">😕</text>
    <text class="empty-text">术语不存在</text>
    <view class="empty-btn" bindtap="goBack">返回上一页</view>
  </view>

  <!-- 底部操作栏 -->
  <view class="action-bar" wx:if="{{term}}">
    <view class="action-item" bindtap="toggleCollection">
      <text class="action-icon">{{isCollected ? '⭐' : '☆'}}</text>
      <text class="action-text">{{isCollected ? '已收藏' : '收藏'}}</text>
    </view>
    
    <view class="action-item" bindtap="showNoteEditor">
      <text class="action-icon">📝</text>
      <text class="action-text">{{hasNote ? '编辑笔记' : '笔记'}}</text>
    </view>
    
    <view class="action-item" bindtap="generateCard">
      <text class="action-icon">🎴</text>
      <text class="action-text">卡片</text>
    </view>
    
    <view class="action-item" bindtap="shareTerm">
      <text class="action-icon">📤</text>
      <text class="action-text">分享</text>
    </view>
  </view>

  <!-- 笔记编辑器弹窗 -->
  <view class="modal-mask" wx:if="{{showNoteEditor}}" bindtap="hideNoteEditor">
    <view class="modal-content" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">{{hasNote ? '编辑笔记' : '添加笔记'}}</text>
        <text class="modal-close" bindtap="hideNoteEditor">×</text>
      </view>
      
      <textarea 
        class="note-input" 
        placeholder="记录你的学习心得..." 
        value="{{noteContent}}"
        bindinput="onNoteInput"
        maxlength="500"
        auto-height
      />
      
      <view class="note-actions">
        <view class="note-btn delete-btn" wx:if="{{hasNote}}" bindtap="deleteNote">
          删除笔记
        </view>
        <view class="note-btn save-btn" bindtap="saveNote">
          保存
        </view>
      </view>
    </view>
  </view>
</view>
