/* pages/profile/notes/index.wxss - 笔记管理页 (宇宙星空主题) */

/* ==================== 容器 ==================== */
.container {
  position: relative;
  min-height: 100vh;
}

/* ==================== 头部区域 ==================== */
.header {
  padding: 96rpx 32rpx 24rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* ==================== 搜索框 ==================== */
.search-section {
  padding: 0 32rpx 24rpx;
}

.search-box {
  position: relative;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 20rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-icon {
  font-size: 36rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.clear-btn {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 0 8rpx;
}

/* ==================== 笔记列表 ==================== */
.notes-scroll {
  height: calc(100vh - 200rpx);
  padding: 0 32rpx;
}

/* ==================== 笔记卡片 ==================== */
.note-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.note-card:active {
  background: rgba(0, 217, 255, 0.08);
  border-color: rgba(0, 217, 255, 0.3);
  transform: translateY(-4rpx);
}

/* 笔记头部 */
.note-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.note-term {
  font-size: 28rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
}

.note-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 笔记内容 */
.note-content {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* ==================== 操作按钮 ==================== */
.note-actions {
  display: flex;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

/* 编辑按钮 */
.action-btn.edit {
  background: rgba(0, 217, 255, 0.15);
  color: #00d9ff;
}

.action-btn.edit:active {
  background: rgba(0, 217, 255, 0.25);
}

/* 删除按钮 */
.action-btn.delete {
  background: rgba(244, 67, 54, 0.15);
  color: #F44336;
}

.action-btn.delete:active {
  background: rgba(244, 67, 54, 0.25);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
  margin-bottom: 24rpx;
}

.empty-text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}
