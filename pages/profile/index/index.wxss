/* pages/profile/index.wxss - 用户中心页 (宇宙星空主题) */

.container {
  position: relative;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 用户信息卡片 */
.profile-header {
  margin: 96rpx 32rpx 24rpx;
  padding: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.avatar-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.1);
}

.level-badge {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #00d9ff 0%, #b794f6 100%);
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: white;
  white-space: nowrap;
  box-shadow: 0 4rpx 16rpx rgba(0, 217, 255, 0.3);
}

.user-details {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 12rpx;
}

.user-stats {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.stat-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.stat-dot {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.3);
}

.user-actions {
  display: flex;
  gap: 16rpx;
}

.action-icon-wrapper {
  padding: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  transition: all 0.3s ease;
}

.action-icon-wrapper:active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.95);
}

.action-icon {
  font-size: 36rpx;
}

/* 学习数据概览 */
.stats-section {
  margin: 0 32rpx 24rpx;
  padding: 32rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  gap: 12rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #00d9ff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
}

/* 功能入口 */
.functions-section {
  padding: 0 32rpx;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  gap: 12rpx;
  position: relative;
  transition: all 0.3s ease;
}

.function-item:active {
  background: rgba(0, 217, 255, 0.08);
  border-color: rgba(0, 217, 255, 0.3);
  transform: translateY(-4rpx);
}

.function-icon {
  font-size: 48rpx;
}

.function-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.function-count {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #00d9ff 0%, #b794f6 100%);
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(0, 217, 255, 0.3);
}

/* 最近学习 */
.recent-section {
  margin: 0 32rpx 24rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-more {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.section-more:active {
  color: #00d9ff;
}

.recent-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.recent-item:active {
  background: rgba(0, 217, 255, 0.08);
  border-color: rgba(0, 217, 255, 0.3);
  transform: translateX(8rpx);
}

.recent-name {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.recent-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 底部占位 */
.bottom-spacer {
  height: 40rpx;
}
