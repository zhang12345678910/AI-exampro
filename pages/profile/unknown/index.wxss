/* pages/profile/unknown/index.wxss - 生词本页 (宇宙星空主题) */

/* ==================== 容器 ==================== */
.container {
  position: relative;
  min-height: 100vh;
}

/* ==================== 头部区域 ==================== */
.header {
  padding: 96rpx 32rpx 24rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* ==================== 列表滚动区域 ==================== */
.terms-scroll {
  height: calc(100vh - 150rpx);
  padding: 0 32rpx;
}

/* ==================== 术语卡片 ==================== */
.term-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

.term-card:active {
  background: rgba(0, 217, 255, 0.08);
  border-color: rgba(0, 217, 255, 0.3);
  transform: translateY(-4rpx);
}

.term-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.term-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
}

/* 错误次数标签 */
.wrong-count {
  padding: 6rpx 16rpx;
  background: rgba(244, 67, 54, 0.15);
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #F44336;
  font-weight: 600;
}

/* ==================== 术语定义 ==================== */
.term-definition {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ==================== 卡片底部 ==================== */
.term-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.term-category {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 已掌握按钮 */
.action-btn {
  padding: 8rpx 16rpx;
  background: rgba(76, 175, 80, 0.15);
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.action-btn:active {
  background: rgba(76, 175, 80, 0.25);
  transform: scale(0.95);
}

.action-btn.mastered .action-text {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: 600;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
  margin-bottom: 24rpx;
}

.empty-text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}

.empty-hint {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
}
