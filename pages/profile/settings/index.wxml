<!--pages/profile/settings/index.wxml - 设置页 (宇宙星空主题)-->
<view class="container">
  <view class="cosmic-bg"></view>
  
  <view class="header">
    <text class="page-title">⚙️ 设置</text>
  </view>

  <scroll-view class="content-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- 外观设置 -->
    <view class="section-card glass-card">
      <view class="section-title">🎨 外观设置</view>
      <view class="setting-item">
        <text class="setting-label">深色模式</text>
        <switch checked="{{darkMode}}" bindchange="toggleDarkMode" color="#00d9ff" />
      </view>
      <view class="setting-item">
        <text class="setting-label">护眼模式</text>
        <switch checked="{{eyeProtection}}" bindchange="toggleEyeProtection" color="#00d9ff" />
      </view>
    </view>

    <!-- 通知设置 -->
    <view class="section-card glass-card">
      <view class="section-title">🔔 通知设置</view>
      <view class="setting-item">
        <text class="setting-label">每日提醒</text>
        <switch checked="{{dailyPush}}" bindchange="toggleDailyPush" color="#00d9ff" />
      </view>
      <view class="setting-item">
        <text class="setting-label">复习提醒</text>
        <switch checked="{{reviewPush}}" bindchange="toggleReviewPush" color="#00d9ff" />
      </view>
    </view>

    <!-- 数据管理 -->
    <view class="section-card glass-card">
      <view class="section-title">💾 数据管理</view>
      <view class="setting-item" bindtap="clearCache">
        <text class="setting-label">清除缓存</text>
        <text class="setting-value">{{cacheSize}}</text>
      </view>
      <view class="setting-item" bindtap="exportData">
        <text class="setting-label">导出数据</text>
        <text class="setting-arrow">→</text>
      </view>
    </view>

    <!-- 关于 -->
    <view class="section-card glass-card">
      <view class="section-title">ℹ️ 关于</view>
      <view class="setting-item" bindtap="checkUpdate">
        <text class="setting-label">检查更新</text>
        <text class="setting-value">v1.0.0</text>
      </view>
      <view class="setting-item" bindtap="showAbout">
        <text class="setting-label">关于我们</text>
        <text class="setting-arrow">→</text>
      </view>
    </view>

    <view class="logout-btn" bindtap="clearAllData">清除所有数据</view>
  </scroll-view>
</view>
