/* pages/profile/settings/index.wxss - 设置页 (宇宙星空主题) */

/* ==================== 容器 ==================== */
.container {
  position: relative;
  min-height: 100vh;
}

/* ==================== 头部区域 ==================== */
.header {
  padding: 96rpx 32rpx 24rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
}

/* ==================== 内容滚动区域 ==================== */
.content-scroll {
  height: calc(100vh - 120rpx);
  padding: 0 32rpx;
}

/* ==================== 设置区块卡片 ==================== */
.section-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
}

.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
}

/* ==================== 设置项 ==================== */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  transition: all 0.3s ease;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  opacity: 0.7;
  transform: translateX(8rpx);
}

/* 设置标签 */
.setting-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 设置值 */
.setting-value {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 箭头图标 */
.setting-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.3);
  transition: transform 0.3s ease;
}

.setting-item:active .setting-arrow {
  transform: translateX(8rpx);
  color: rgba(0, 217, 255, 0.7);
}

/* ==================== 清除数据按钮 ==================== */
.logout-btn {
  margin: 32rpx;
  padding: 28rpx 0;
  background: rgba(244, 67, 54, 0.15);
  border: 1rpx solid rgba(244, 67, 54, 0.3);
  border-radius: 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #F44336;
  font-weight: 600;
  transition: all 0.3s ease;
}

.logout-btn:active {
  background: rgba(244, 67, 54, 0.25);
  border-color: rgba(244, 67, 54, 0.5);
  transform: scale(0.98);
}
