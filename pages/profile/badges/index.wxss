/* pages/profile/badges/index.wxss - 勋章墙页 (宇宙星空主题) */

/* ==================== 容器 ==================== */
.container {
  position: relative;
  min-height: 100vh;
}

/* ==================== 头部区域 ==================== */
.header {
  padding: 96rpx 32rpx 24rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* ==================== 勋章滚动区域 ==================== */
.badges-scroll {
  height: calc(100vh - 150rpx);
  padding: 0 32rpx;
}

/* ==================== 勋章网格 ==================== */
.badges-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

/* ==================== 勋章卡片 ==================== */
.badge-item {
  padding: 32rpx 24rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  transition: all 0.3s ease;
}

/* 已解锁勋章 */
.badge-item.unlocked {
  background: rgba(0, 217, 255, 0.1);
  border: 1rpx solid rgba(0, 217, 255, 0.3);
  box-shadow: 0 0 32rpx rgba(0, 217, 255, 0.2);
}

.badge-item.unlocked:active {
  transform: scale(0.98);
  box-shadow: 0 0 16rpx rgba(0, 217, 255, 0.3);
}

/* 未解锁勋章 */
.badge-item.locked {
  opacity: 0.5;
  filter: grayscale(80%);
}

/* ==================== 勋章图标 ==================== */
.badge-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.badge-item.unlocked .badge-icon {
  filter: drop-shadow(0 0 16rpx rgba(0, 217, 255, 0.5));
}

/* ==================== 勋章名称 ==================== */
.badge-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

/* ==================== 解锁条件 ==================== */
.badge-condition {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.badge-item.unlocked .badge-condition {
  color: rgba(0, 217, 255, 0.7);
}

/* ==================== 解锁日期 ==================== */
.badge-date {
  display: block;
  font-size: 20rpx;
  color: rgba(0, 217, 255, 0.7);
  margin-top: 12rpx;
  font-weight: 500;
}
