/* pages/profile/stats/index.wxss - 学习记录页 (宇宙星空主题) */

/* ==================== 容器 ==================== */
.container {
  position: relative;
  min-height: 100vh;
}

/* ==================== 头部区域 ==================== */
.header {
  padding: 96rpx 32rpx 24rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* ==================== 内容滚动区域 ==================== */
.content-scroll {
  height: calc(100vh - 120rpx);
  padding: 0 32rpx;
}

/* ==================== 统计卡片 ==================== */
.stats-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #00d9ff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ==================== 区块卡片 ==================== */
.section-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

/* ==================== 测验列表 ==================== */
.quiz-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quiz-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.quiz-item:active {
  background: rgba(0, 217, 255, 0.08);
  transform: translateX(8rpx);
}

.quiz-header {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.quiz-date {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.quiz-level {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 分数样式 */
.quiz-score {
  font-size: 32rpx;
  font-weight: bold;
}

/* 优秀 (≥80 分) */
.quiz-score.excellent {
  color: #4CAF50;
  text-shadow: 0 0 16rpx rgba(76, 175, 80, 0.5);
}

/* 及格 (60-79 分) */
.quiz-score.pass {
  color: #FFC107;
}

/* 不及格 (<60 分) */
.quiz-score.fail {
  color: #F44336;
}

/* ==================== 最近学习列表 ==================== */
.recent-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.recent-item:active {
  background: rgba(0, 217, 255, 0.08);
  transform: translateX(8rpx);
}

.recent-name {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

.recent-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ==================== 空状态提示 ==================== */
.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: rgba(255, 255, 255, 0.4);
  font-size: 26rpx;
}
