/* pages/learning/level/index.wxss - 分级学习页 (宇宙星空主题) */

.container {
  position: relative;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 头部 */
.header {
  padding: 96rpx 32rpx 32rpx;
  text-align: center;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
  font-family: var(--font-display);
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 内容滚动区域 */
.content-scroll {
  height: calc(100vh - 160rpx);
  padding: 0 32rpx;
}

/* 级别卡片 */
.level-card {
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.level-card.locked {
  opacity: 0.7;
}

.level-card-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(0, 217, 255, 0.05) 0%, rgba(183, 148, 246, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.level-card:active:not(.locked) .level-card-bg {
  opacity: 1;
}

.level-card:active:not(.locked) {
  transform: translateY(-4rpx);
  border-color: rgba(0, 217, 255, 0.3);
}

.level-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.level-icon-wrapper {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.level-icon {
  font-size: 64rpx;
}

.level-lock {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  font-size: 32rpx;
  opacity: 0.8;
}

.level-info {
  flex: 1;
}

.level-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 8rpx;
}

.level-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 进度条 */
.level-progress {
  margin-bottom: 24rpx;
  position: relative;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.progress-percent {
  font-size: 24rpx;
  font-weight: 600;
  color: #00d9ff;
}

.progress-bar-bg {
  width: 100%;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #00d9ff 0%, #b794f6 100%);
  border-radius: 6rpx;
  transition: width 0.5s ease;
  box-shadow: 0 0 16rpx rgba(0, 217, 255, 0.5);
}

/* 开始按钮 */
.level-action {
  position: relative;
}

.start-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 0;
  background: linear-gradient(135deg, #00d9ff 0%, #b794f6 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 217, 255, 0.3);
  transition: all 0.3s ease;
}

.start-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 217, 255, 0.2);
}

.start-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: white;
}

.start-btn-arrow {
  font-size: 28rpx;
  color: white;
  transition: transform 0.3s ease;
}

.start-btn:active .start-btn-arrow {
  transform: translateX(8rpx);
}

/* 锁定提示 */
.locked-hint {
  text-align: center;
  padding: 16rpx 0;
}

.locked-hint text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 打卡区域 */
.checkin-section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.checkin-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #00d9ff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
}

.checkin-action {
  margin-bottom: 20rpx;
}

.checkin-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #00d9ff 0%, #b794f6 100%);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 217, 255, 0.3);
  transition: all 0.3s ease;
}

.checkin-btn.checked {
  background: rgba(255, 255, 255, 0.1);
  box-shadow: none;
}

.checkin-btn:active {
  transform: scale(0.98);
}

.checkin-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: white;
}

.checkin-btn.checked .checkin-btn-text {
  color: rgba(255, 255, 255, 0.7);
}

.checkin-btn-icon {
  font-size: 32rpx;
}

.checkin-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.checkin-link-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.checkin-link-arrow {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.4);
  transition: transform 0.3s ease;
}

.checkin-link:active .checkin-link-arrow {
  transform: translateX(8rpx);
}

/* 测试区域 */
.quiz-section {
  margin-bottom: 24rpx;
}

.quiz-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quiz-item {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.quiz-item:active:not(.locked) {
  background: rgba(0, 217, 255, 0.08);
  border-color: rgba(0, 217, 255, 0.3);
  transform: translateX(8rpx);
}

.quiz-item.locked {
  opacity: 0.5;
}

.quiz-item-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.quiz-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.quiz-count {
  padding: 6rpx 16rpx;
  background: rgba(0, 217, 255, 0.15);
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #00d9ff;
}

.quiz-lock {
  font-size: 28rpx;
}

.quiz-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 底部占位 */
.bottom-spacer {
  height: 40rpx;
}
