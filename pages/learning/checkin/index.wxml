<!--pages/learning/checkin/index.wxml - 打卡日历页 (宇宙星空主题)-->
<view class="container">
  <!-- 宇宙背景 -->
  <view class="cosmic-bg"></view>
  
  <!-- 头部 -->
  <view class="header">
    <text class="page-title">📅 打卡日历</text>
    <text class="page-subtitle">记录你的学习足迹</text>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-card glass-card">
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{continuousCheckInDays}}</text>
        <text class="stat-label">连续打卡</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{totalCheckInDays}}</text>
        <text class="stat-label">总打卡天数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{currentStreak}}天</text>
        <text class="stat-label">当前连续</text>
      </view>
    </view>
  </view>

  <!-- 日历 -->
  <view class="calendar-section glass-card">
    <view class="calendar-header">
      <text class="calendar-btn" bindtap="prevMonth">‹</text>
      <text class="calendar-title">{{currentYear}}年{{currentMonth}}月</text>
      <text class="calendar-btn" bindtap="nextMonth">›</text>
    </view>
    
    <view class="calendar-weekdays">
      <view class="weekday" wx:for="{{weekdays}}" wx:key="*this">{{item}}</view>
    </view>
    
    <view class="calendar-days">
      <view 
        class="day-cell {{item.isToday ? 'today' : ''}} {{item.isCheckedIn ? 'checked' : ''}} {{item.isFuture ? 'future' : ''}}"
        wx:for="{{calendarDays}}"
        wx:key="date"
        data-date="{{item.date}}"
        bindtap="selectDay"
      >
        <text class="day-number">{{item.day}}</text>
        <text class="checkin-icon" wx:if="{{item.isCheckedIn}}">✅</text>
      </view>
    </view>
  </view>

  <!-- 打卡规则 -->
  <view class="rules-section glass-card">
    <view class="section-title">📋 打卡规则</view>
    <view class="rule-item">
      <text class="rule-icon">✓</text>
      <text class="rule-text">每天学习任意术语即可打卡</text>
    </view>
    <view class="rule-item">
      <text class="rule-icon">✓</text>
      <text class="rule-text">连续打卡可解锁勋章奖励</text>
    </view>
    <view class="rule-item">
      <text class="rule-icon">✓</text>
      <text class="rule-text">打卡记录永久保存</text>
    </view>
  </view>

  <!-- 勋章预览 -->
  <view class="badges-preview glass-card" wx:if="{{availableBadges.length > 0}}">
    <view class="section-title">🏅 可解锁勋章</view>
    <view class="badges-list">
      <view 
        class="badge-item {{item.unlocked ? 'unlocked' : 'locked'}}"
        wx:for="{{availableBadges}}"
        wx:key="badgeId"
      >
        <text class="badge-icon">{{item.icon}}</text>
        <text class="badge-name">{{item.name}}</text>
        <text class="badge-condition">{{item.condition}}</text>
      </view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-spacer"></view>

  <!-- 底部导航栏 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{currentTab === 'home' ? 'active' : ''}}"
      data-tab="home"
      bindtap="switchTab"
    >
      <text class="tab-icon">🏠</text>
      <text class="tab-label">首页</text>
    </view>
    <view 
      class="tab-item {{currentTab === 'dictionary' ? 'active' : ''}}"
      data-tab="dictionary"
      bindtap="switchTab"
    >
      <text class="tab-icon">📖</text>
      <text class="tab-label">词典</text>
    </view>
    <view 
      class="tab-item {{currentTab === 'learning' ? 'active' : ''}}"
      data-tab="learning"
      bindtap="switchTab"
    >
      <text class="tab-icon">📚</text>
      <text class="tab-label">学习</text>
    </view>
    <view 
      class="tab-item {{currentTab === 'profile' ? 'active' : ''}}"
      data-tab="profile"
      bindtap="switchTab"
    >
      <text class="tab-icon">👤</text>
      <text class="tab-label">我的</text>
    </view>
  </view>
</view>
