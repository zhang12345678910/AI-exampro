/* pages/learning/detail/index.wxss - 学习详情页 */
.container { position: relative; min-height: 100vh; }
.empty-container { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; padding: 0 32rpx; text-align: center; }
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: rgba(255,255,255,0.9); margin-bottom: 16rpx; }
.empty-hint { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 48rpx; }
.back-btn { padding: 20rpx 48rpx; background: rgba(0,217,255,0.15); border: 1rpx solid rgba(0,217,255,0.3); border-radius: 32rpx; color: #00d9ff; font-size: 28rpx; font-weight: 600; }
.back-btn:active { background: rgba(0,217,255,0.25); }
