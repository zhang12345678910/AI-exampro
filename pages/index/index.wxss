/* pages/index/index.wxss - 首页样式 (宇宙星空主题) */

.container {
  position: relative;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 头部 */
.header {
  padding: 96rpx 32rpx 32rpx;
  text-align: center;
}

.title-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #00d9ff 0%, #b794f6 50%, #ec4899 100%);
  background-clip: text;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-family: var(--font-display);
}

.title-emoji {
  font-size: 40rpx;
}

.subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 搜索区域 */
.search-section {
  padding: 0 32rpx 32rpx;
}

.search-box {
  position: relative;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-icon {
  font-size: 36rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.clear-btn {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 0 8rpx;
  line-height: 1;
}

/* 内容滚动区域 */
.content-scroll {
  height: calc(100vh - 300rpx);
  padding: 0 32rpx;
}

/* 每日一词卡片 */
.daily-word-card {
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
}

.daily-word-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(0, 217, 255, 0.1) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.daily-word-card:active::before {
  opacity: 1;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.card-icon {
  font-size: 32rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.8);
}

.term-content {
  margin-bottom: 32rpx;
}

.term-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
  margin-bottom: 8rpx;
  font-family: var(--font-display);
}

.term-name-en {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
}

.term-definition {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.8;
  text-align: justify;
}

.card-actions {
  display: flex;
  justify-content: space-around;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.action-btn:active {
  background: rgba(255, 255, 255, 0.05);
}

.action-icon {
  font-size: 40rpx;
}

.action-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 分类区域 */
.categories-section {
  margin-bottom: 32rpx;
}

.categories-scroll {
  width: 100%;
}

.categories-list {
  display: flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}

.category-item {
  flex-shrink: 0;
  width: 200rpx;
  padding: 24rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.category-item:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.08);
}

.category-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.category-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.category-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 热门名词区域 */
.hot-terms-section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

.hot-terms-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hot-term-item {
  padding: 24rpx;
  transition: all 0.3s ease;
}

.hot-term-item:active {
  transform: translateY(-4rpx);
  border-color: rgba(0, 217, 255, 0.3);
}

.hot-term-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.hot-term-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
}

/* 难度标签 - 统一样式 */
.difficulty-tag {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  background: rgba(0, 217, 255, 0.15);
  color: #00d9ff;
}

/* 注意：WXSS 不支持 wx:if 条件，需要在 WXML 中使用 class 控制 */

.hot-term-category {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: #00d9ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  opacity: 0.5;
  margin-bottom: 24rpx;
}

.empty-text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 28rpx;
}

.empty-hint {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.4);
  font-size: 24rpx;
}
