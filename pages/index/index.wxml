<!--pages/index/index.wxml - 首页 (宇宙星空主题)-->
<view class="container">
  <!-- 宇宙背景 -->
  <view class="cosmic-bg"></view>
  <view class="stars">
    <view class="star" style="top: {{item.top}}%; left: {{item.left}}%; animation-delay: {{item.delay}}s;" wx:for="{{stars}}" wx:key="index"></view>
  </view>

  <!-- 头部 -->
  <view class="header">
    <view class="title-wrapper">
      <text class="title">AI 词星球</text>
      <text class="title-emoji">🌍</text>
    </view>
    <text class="subtitle">探索 AI 知识宇宙</text>
  </view>

  <!-- 搜索框 -->
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索 AI 术语..." 
        value="{{searchValue}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearchConfirm"
      />
      <text 
        class="clear-btn" 
        wx:if="{{searchValue}}"
        bindtap="clearSearch"
      >×</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <scroll-view 
    class="content-scroll" 
    scroll-y 
    enhanced
    show-scrollbar="{{false}}"
  >
    <!-- 每日一词卡片 -->
    <view class="daily-word-card glass-card" wx:if="{{dailyWord}}">
      <view class="card-header">
        <text class="card-icon">📅</text>
        <text class="card-title">每日一词</text>
      </view>
      
      <view class="term-content">
        <text class="term-name">{{dailyWord.name}}</text>
        <text class="term-name-en" wx:if="{{dailyWord.nameEn}}">{{dailyWord.nameEn}}</text>
        <text class="term-definition">{{dailyWord.definition}}</text>
      </view>
      
      <view class="card-actions">
        <view class="action-btn" bindtap="toggleCheckIn">
          <text class="action-icon">{{isCheckInToday ? '✅' : '📝'}}</text>
          <text class="action-text">{{isCheckInToday ? '已打卡' : '打卡'}}</text>
        </view>
        <view class="action-btn" bindtap="toggleCollection">
          <text class="action-icon">{{isCollected ? '⭐' : '☆'}}</text>
          <text class="action-text">{{isCollected ? '已收藏' : '收藏'}}</text>
        </view>
        <view class="action-btn" bindtap="shareDailyWord">
          <text class="action-icon">📤</text>
          <text class="action-text">分享</text>
        </view>
      </view>
    </view>

    <!-- 分类入口 -->
    <view class="categories-section">
      <scroll-view class="categories-scroll" scroll-x show-scrollbar="{{false}}">
        <view class="categories-list">
          <view 
            class="category-item glass-card"
            wx:for="{{categories}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="selectCategory"
          >
            <text class="category-icon">{{item.icon}}</text>
            <text class="category-name">{{item.name}}</text>
            <text class="category-desc">{{item.desc}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 热门名词 -->
    <view class="hot-terms-section">
      <view class="section-header">
        <text class="section-icon">🔥</text>
        <text class="section-title">热门名词</text>
      </view>
      
      <view class="hot-terms-list">
        <view 
          class="hot-term-item glass-card"
          wx:for="{{hotTerms}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="goToDetail"
        >
          <view class="hot-term-header">
            <text class="hot-term-name">{{item.name}}</text>
            <view class="difficulty-tag" wx:if="{{item.difficulty === 1}}">入门</view>
            <view class="difficulty-tag" wx:if="{{item.difficulty === 2}}">进阶</view>
            <view class="difficulty-tag" wx:if="{{item.difficulty === 3}}">专业</view>
          </view>
          <text class="hot-term-category">{{item.category}}</text>
        </view>
      </view>
    </view>

    <!-- 分类入口 -->
    <view class="categories-section">
      <scroll-view class="categories-scroll" scroll-x show-scrollbar="{{false}}">
        <view class="categories-list">
          <view 
            class="category-item glass-card"
            wx:for="{{categories}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="selectCategory"
          >
            <text class="category-icon">{{item.icon}}</text>
            <text class="category-name">{{item.name}}</text>
            <text class="category-desc">{{item.desc}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 热门名词 -->
    <view class="hot-terms-section">
      <view class="section-header">
        <text class="section-icon">🔥</text>
        <text class="section-title">热门名词</text>
      </view>
      
      <view class="hot-terms-list">
        <view 
          class="hot-term-item glass-card"
          wx:for="{{hotTerms}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="goToDetail"
        >
          <view class="hot-term-header">
            <text class="hot-term-name">{{item.name}}</text>
            <view class="difficulty-tag" wx:if="{{item.difficulty === 1}}">入门</view>
            <view class="difficulty-tag" wx:if="{{item.difficulty === 2}}">进阶</view>
            <view class="difficulty-tag" wx:if="{{item.difficulty === 3}}">专业</view>
          </view>
          <text class="hot-term-category">{{item.category}}</text>
        </view>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="loading-container" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在加载...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && hotTerms.length === 0}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">暂无数据</text>
      <text class="empty-hint">下拉刷新试试</text>
    </view>
  </scroll-view>

  <!-- 底部导航栏 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{currentTab === 'home' ? 'active' : ''}}"
      data-tab="home"
      bindtap="switchTab"
    >
      <text class="tab-icon">🏠</text>
      <text class="tab-label">首页</text>
    </view>
    <view 
      class="tab-item {{currentTab === 'dictionary' ? 'active' : ''}}"
      data-tab="dictionary"
      bindtap="switchTab"
    >
      <text class="tab-icon">📖</text>
      <text class="tab-label">词典</text>
    </view>
  </scroll-view>
</view>
