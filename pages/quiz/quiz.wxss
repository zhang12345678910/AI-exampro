/* pages/quiz/quiz.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 开始页面 */
.start-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 80vh;
}

.quiz-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.quiz-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.quiz-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 60rpx;
}

.btn-start {
  background-color: #07c160;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 80rpx;
  font-size: 32rpx;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 8rpx;
  background-color: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress {
  height: 100%;
  background-color: #07c160;
  transition: width 0.3s;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  text-align: right;
  margin-bottom: 20rpx;
}

/* 题目卡片 */
.question-card {
  margin-bottom: 30rpx;
}

.question-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.6;
}

/* 选项 */
.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-card {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  transition: all 0.2s;
}

.option-card.selected {
  background-color: #e8f5e9;
  border: 2rpx solid #07c160;
}

.option-card:active {
  background-color: #f5f5f5;
}

.option-index {
  font-size: 28rpx;
  font-weight: 600;
  color: #07c160;
  margin-right: 16rpx;
  min-width: 40rpx;
}

.option-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
}

/* 结果页面 */
.result-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 60rpx;
}

.score-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 8rpx solid #07c160;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.score {
  font-size: 60rpx;
  font-weight: 600;
  color: #07c160;
}

.score-total {
  font-size: 24rpx;
  color: #999;
}

.result-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.result-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 60rpx;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

.btn-restart {
  background-color: #07c160;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
}

.btn-home {
  background-color: #fff;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
}
